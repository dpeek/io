{
  "name": "@io/app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#graph": "./src/index.ts",
    "#web/*": "./src/web/*"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "clean": "rm -rf out",
    "build": "tsgo",
    "check": "bun run lint && bun run types && bun test src",
    "format": "oxfmt",
    "lint": "oxlint",
    "types": "tsgo --noEmit",
    "test": "bun test src",
    "dev": "portless graph bun run --hot-reload --watch ./src/server.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@io/graph": "workspace:*",
    "@io/lib": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "@vitejs/plugin-rsc": "^0.5.19",
    "bun": "1.3.9",
    "bun-plugin-tailwind": "^0.1.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "react-server-dom-webpack": "^19.2.4",
    "react-test-renderer": "^19.2.4",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1",
    "wrangler": "^4.70.0"
  }
}
