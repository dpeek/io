{
  "$schema": "https://turborepo.dev/schema.json",
  "envMode": "loose",
  "tasks": {
    "clean": {
      "outputLogs": "none"
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**"]
    },
    "check": {
      "dependsOn": ["^check"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
