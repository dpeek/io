{
  "$schema": "https://turborepo.dev/schema.json",
  "envMode": "loose",
  "tasks": {
    "clean": {
      "outputLogs": "none"
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**"],
      "outputLogs": "errors-only"
    },
    "check": {
      "dependsOn": ["build", "^build", "^check"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "dev:setup": {
      "cache": false,
      "outputs": []
    },
    "dev:setup:clean": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "dependsOn": ["dev:setup"],
      "cache": false,
      "persistent": true
    },
    "dev:clean": {
      "dependsOn": ["dev:setup:clean"],
      "cache": false,
      "persistent": true
    }
  }
}
