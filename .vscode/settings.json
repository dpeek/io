{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "ts.preferences.importModuleSpecifierEnding": "js",
  "ts.reportStyleChecksAsWarnings": false,
  "ts.updateImportsOnFileMove.enabled": "always",
  "ts.experimental.useTsgo": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,
  "workbench.startupEditor": "none",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "files.exclude": {
    "**/.vscode": false,
    "**/node_modules": false,
    "**/bun.lock": false,
    "**/.gitignore": false,
    "**/tsconfig.json": false,
    "**/package.json": false,
    "**/bunfig.toml": false,
    "**/.env": false,
    "**/tmp": false
  }
}
