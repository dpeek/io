{
  "name": "@io/graph-integration",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./out/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./out/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "clean": "rm -rf out",
    "check": "oxlint --type-aware --type-check --fix src --ignore-pattern '**/*.test.ts' && oxfmt && bun test ./src"
  },
  "dependencies": {
    "@io/graph-authority": "workspace:*",
    "@io/graph-bootstrap": "workspace:*",
    "@io/graph-client": "workspace:*",
    "@io/graph-kernel": "workspace:*",
    "@io/graph-module": "workspace:*",
    "@io/graph-module-core": "workspace:*",
    "@io/graph-react": "workspace:*",
    "@io/graph-sync": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  }
}
