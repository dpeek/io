{
  "name": "@dpeek/graphle-query",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./out/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./out/index.js"
    },
    "./react-dom": {
      "types": "./src/react-dom/index.ts",
      "default": "./out/react-dom/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "clean": "rm -rf out",
    "check": "oxlint --type-aware --type-check --fix src --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.test.tsx' && oxfmt && bun test ./src"
  },
  "dependencies": {
    "@dpeek/graphle-client": "workspace:*",
    "@dpeek/graphle-kernel": "workspace:*",
    "@dpeek/graphle-module": "workspace:*",
    "@dpeek/graphle-module-core": "workspace:*",
    "@dpeek/graphle-projection": "workspace:*",
    "@dpeek/graphle-web-ui": "workspace:*",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@dpeek/graphle-bootstrap": "workspace:*",
    "@dpeek/graphle-module-workflow": "workspace:*",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "react-dom": "^19.2.4"
  }
}
