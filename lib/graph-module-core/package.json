{
  "name": "@io/graph-module-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#*": "./out/*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./out/index.js"
    },
    "./react-dom": {
      "types": "./src/react-dom/index.ts",
      "default": "./out/react-dom/index.js"
    }
  },
  "scripts": {
    "build": "tsgo",
    "clean": "rm -rf out",
    "check": "oxlint --type-aware --type-check --fix src --ignore-pattern '**/*.test.ts' && oxfmt && bun test ./src"
  },
  "dependencies": {
    "@io/graph-bootstrap": "workspace:*",
    "@io/graph-client": "workspace:*",
    "@io/graph-kernel": "workspace:*",
    "@io/graph-module": "workspace:*",
    "@io/graph-projection": "workspace:*",
    "@io/graph-react": "workspace:*",
    "@io/web": "workspace:*",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "react-dom": "^19.2.4"
  }
}
