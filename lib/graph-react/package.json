{
  "name": "@io/graph-react",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "types": "./out/index.d.ts",
  "exports": {
    ".": {
      "types": "./out/index.d.ts",
      "default": "./out/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "check": "vp check ./src",
    "clean": "rm -rf out",
    "format": "vp fmt ./src",
    "lint": "vp lint ./src",
    "test": "bun test ./src",
    "types": "tsgo --noEmit"
  },
  "dependencies": {
    "@io/graph-client": "workspace:*",
    "@io/graph-kernel": "workspace:*",
    "@io/graph-module": "workspace:*",
    "@io/graph-sync": "workspace:*",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "vite-plus": "^0.1.14"
  }
}
