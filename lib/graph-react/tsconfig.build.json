{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "noEmit": false,
    "outDir": "./out",
    "rewriteRelativeImportExtensions": true,
    "rootDir": "./src"
  },
  "include": ["./src/**/*.ts", "./src/**/*.tsx"],
  "exclude": ["./src/**/*.test.ts", "./src/**/*.test.tsx", "./src/**/*.typecheck.ts"]
}
