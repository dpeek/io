{
  "name": "@io/core",
  "version": "1.0.0",
  "private": true,
  "bin": {
    "io": "./src/cli/index.ts"
  },
  "workspaces": [
    "lib/*"
  ],
  "type": "module",
  "exports": {
    "./agent": "./src/agent/index.ts",
    "./browser-agent": "./src/browser-agent/index.ts",
    "./cli": "./src/cli/index.ts",
    "./config": "./src/config/index.ts",
    "./graph": "./src/graph/index.ts",
    "./web/query-container": "./src/web/lib/query-container.ts",
    "./lib": "./src/lib/index.ts",
    "./lib/config": "./src/lib/config.ts",
    "./tsconfig/base": "./tsconfig.base.json"
  },
  "scripts": {
    "check": "bun src/cli/index.ts check",
    "auth:migrations:apply:local": "wrangler d1 migrations apply AUTH_DB --local --persist-to out/wrangler",
    "auth:migrations:apply:remote": "wrangler d1 migrations apply AUTH_DB --remote",
    "auth:migrations:create": "wrangler d1 migrations create AUTH_DB",
    "auth:migrations:generate": "better-auth generate --config auth.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@io/graph-authority": "workspace:*",
    "@io/graph-bootstrap": "workspace:*",
    "@io/graph-client": "workspace:*",
    "@io/graph-kernel": "workspace:*",
    "@io/graph-module": "workspace:*",
    "@io/graph-module-core": "workspace:*",
    "@io/graph-module-workflow": "workspace:*",
    "@io/graph-projection": "workspace:*",
    "@io/graph-react": "workspace:*",
    "@io/graph-sync": "workspace:*",
    "@io/web": "workspace:*",
    "@linear/sdk": "^76.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "@tanstack/react-router": "^1.167.4",
    "better-auth": "1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.166.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "@vitejs/plugin-react": "^6.0.1",
    "auth": "1.5.6",
    "better-sqlite3": "^12.8.0",
    "bun": "1.3.9",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
