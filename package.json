    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "@vitejs/plugin-react": "^6.0.1",
    "auth": "1.5.6",
    "better-sqlite3": "^12.8.0",
    "bun": "1.3.9",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
