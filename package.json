{
  "name": "@io/root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "lib/*"
  ],
  "type": "module",
  "scripts": {
    "build": "vp run --filter './lib/*' build",
    "check": "sh -c \"vp run --filter './lib/*' check && vp check ./auth.ts ./io.ts ./vite.config.ts\"",
    "format": "vp run --filter './lib/*' format && vp fmt ./auth.ts ./io.ts ./vite.config.ts",
    "lint": "vp run --filter './lib/*' lint && vp lint ./auth.ts ./io.ts ./vite.config.ts",
    "test": "vp run --filter './lib/*' test",
    "auth:migrations:apply:local": "wrangler d1 migrations apply AUTH_DB --local --persist-to out/wrangler",
    "auth:migrations:apply:remote": "wrangler d1 migrations apply AUTH_DB --remote",
    "auth:migrations:create": "wrangler d1 migrations create AUTH_DB",
    "auth:migrations:generate": "better-auth generate --config auth.ts"
  },
  "devDependencies": {
    "auth": "1.5.6",
    "better-sqlite3": "^12.8.0",
    "bun": "1.3.9",
    "wrangler": "^4.74.0"
  }
}
