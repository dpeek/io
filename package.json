{
  "name": "@dpeek/graphle",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "lib/*"
  ],
  "type": "module",
  "scripts": {
    "clean": "rm -rf .turbo/cache lib/*/.turbo lib/*/out",
    "dev:clean": "turbo dev:clean --filter=@dpeek/graphle-app",
    "web:dev": "turbo dev --filter=@dpeek/graphle-app"
  },
  "devDependencies": {
    "@dpeek/graphle": "workspace:*",
    "@types/node": "^25.3.2",
    "bun": "1.3.10",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.18.1",
    "react-dom": "^19.2.4",
    "turbo": "^2.8.20"
  },
  "packageManager": "bun@1.3.10"
}
