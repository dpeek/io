{
  "name": "@io/core",
  "version": "1.0.0",
  "private": true,
  "bin": {
    "io": "./src/cli/index.ts"
  },
  "workspaces": [
    "lib/*"
  ],
  "type": "module",
  "exports": {
    "./agent": "./src/agent/index.ts",
    "./browser-agent": "./src/browser-agent/index.ts",
    "./cli": "./src/cli/index.ts",
    "./config": "./src/config/index.ts",
    "./graph": "./src/graph/index.ts",
    "./graph/runtime": "./src/graph/runtime/index.ts",
    "./graph/runtime/react": "./src/graph/runtime/react/index.ts",
    "./graph/authority": "./src/graph/runtime/authority.ts",
    "./graph/def": "./src/graph/runtime/def.ts",
    "./graph/modules": "./src/graph/modules/index.ts",
    "./graph/modules/core": "./src/graph/modules/core.ts",
    "./graph/modules/ops": "./src/graph/modules/ops.ts",
    "./graph/modules/ops/env-var": "./src/graph/modules/ops/env-var/schema.ts",
    "./graph/modules/ops/workflow": "./src/graph/modules/ops/workflow/schema.ts",
    "./graph/modules/pkm": "./src/graph/modules/pkm.ts",
    "./graph/modules/pkm/document": "./src/graph/modules/pkm/document/schema.ts",
    "./graph/adapters/react-dom": "./src/graph/adapters/react-dom/index.ts",
    "./graph/adapters/react-opentui": "./src/graph/adapters/react-opentui/index.ts",
    "./lib": "./src/lib/index.ts",
    "./lib/config": "./src/lib/config.ts",
    "./tsconfig/base": "./tsconfig.base.json"
  },
  "scripts": {
    "check": "bun src/cli/index.ts check",
    "auth:migrations:apply:local": "wrangler d1 migrations apply AUTH_DB --local --persist-to out/wrangler",
    "auth:migrations:apply:remote": "wrangler d1 migrations apply AUTH_DB --remote",
    "auth:migrations:create": "wrangler d1 migrations create AUTH_DB",
    "auth:migrations:generate": "better-auth generate --config auth.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@io/web": "workspace:*",
    "@linear/sdk": "^76.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "@tanstack/react-router": "^1.167.4",
    "better-auth": "1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.25.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.166.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.9",
