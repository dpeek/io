{
  "name": "@io/graph",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#graph": "./src/graph/index.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react/index.ts",
    "./react-dom": "./src/react-dom/index.ts",
    "./react-opentui": "./src/react-opentui/index.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/*": "./src/schema/*/index.ts",
    "./taxonomy/*": "./src/taxonomy/*.ts"
  },
  "scripts": {
    "clean": "rm -rf out",
    "build": "tsgo",
    "check": "bun run lint && bun run types && bun test src",
    "format": "oxfmt",
    "lint": "oxlint",
    "types": "tsgo --noEmit",
    "test": "bun test src",
    "ids": "bun run src/ids-cli.ts"
  },
  "dependencies": {
    "@io/lib": "workspace:*",
    "nanoid": "^5.1.6",
    "react": "^19.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript/native-preview": "^7.0.0-dev.20260226.1",
    "bun": "1.3.9",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "react-test-renderer": "^19.2.4"
  }
}
